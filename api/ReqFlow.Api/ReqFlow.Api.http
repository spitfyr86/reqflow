@ReqFlow_Api_HostAddress = http://localhost:5000
@RequesterUserId = 10000000-0000-0000-0000-000000000001
@AccessToken = paste-token-from-login

GET {{ReqFlow_Api_HostAddress}}/health

###

POST {{ReqFlow_Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userId": "{{RequesterUserId}}"
}

###

GET {{ReqFlow_Api_HostAddress}}/api/requests
Accept: application/json
Authorization: Bearer {{AccessToken}}

###

GET {{ReqFlow_Api_HostAddress}}/api/requests/pending-count
Accept: application/json
Authorization: Bearer {{AccessToken}}

###

POST {{ReqFlow_Api_HostAddress}}/api/requests
Content-Type: application/json
Authorization: Bearer {{AccessToken}}

{
  "title": "New laptop",
  "description": "Replacement laptop for a developer."
}
